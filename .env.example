# === Supabase (proyecto: Control Partes Talleristas) ===
# La URL no es secreta.
NEXT_PUBLIC_SUPABASE_URL=https://hrxfctzncixxqmpfhskv.supabase.co

# SECRETO. NO commitear. Sacala de: Supabase Dashboard -> Project Settings -> API -> service_role (secret)
